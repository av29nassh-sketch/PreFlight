{
  "name": "preflight-guardian",
  "version": "0.2.0-beta.1",
  "description": "The local security gate for AI-generated code.",
  "license": "BUSL-1.1",
  "type": "commonjs",
  "homepage": "https://github.com/av29nassh-sketch/PreFlight#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/av29nassh-sketch/PreFlight.git"
  },
  "bugs": {
    "url": "https://github.com/av29nassh-sketch/PreFlight/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "preflight",
    "security",
    "ai-code",
    "nextjs",
    "supabase",
    "secret-scanner",
    "mcp",
    "cli"
  ],
  "files": [
    "index.js",
    "logger.js",
    "remediationEngine.js",
    "scaffoldEngine.js",
    "taintTracker.js",
    "src/**/*.js",
    "wasm/*.wasm",
    "mcp-instructions.md",
    "README.md"
  ],
  "bin": {
    "preflight": "index.js",
    "preflight-guardian": "index.js"
  },
  "scripts": {
    "test": "vitest run --globals",
    "demo:reset": "node reset-demo.js",
    "scan": "node index.js",
    "build:bin": "pkg . --out-path dist",
    "build:bin:mac": "pkg . --targets node18-macos-x64,node18-macos-arm64 --no-bytecode --public --public-packages \"*\" --out-path dist",
    "build:bin:win": "pkg . --targets node18-win-x64 --out-path dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "openai": "^6.41.0",
    "pgsql-ast-parser": "^12.0.1",
    "picocolors": "^1.1.1",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "targets": [
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-win-x64"
    ],
    "outputPath": "dist"
  }
}
