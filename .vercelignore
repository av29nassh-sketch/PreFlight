dist/
*.exe
*.dmg
*.pkg
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Local demo/test sandboxes
demo-sandbox/
test-sandbox/
hardcore-test-suite/

# Logs, traces, and reports
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
test-results/
playwright-report/
temporary screenshots/
*.heapsnapshot
*.trace
*.trace.json
*.trace.json.gz

