{
  "name": "preflight-companion",
  "displayName": "PreFlight Companion (Beta)",
  "description": "Real-time AI code drift and security guarding for the PreFlight Pro Engine (Beta)",
  "version": "0.0.11",
  "publisher": "PreflightPro",
  "icon": "assets/preflight-icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onCommand:preflight.fixIssue"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./"
  },
  "contributes": {
    "commands": [
      {
        "command": "preflight.fixIssue",
        "title": "PreFlight: Fix Issue"
      }
    ]
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@types/ws": "^8.18.1",
    "@types/vscode": "^1.90.0"
  }
}
